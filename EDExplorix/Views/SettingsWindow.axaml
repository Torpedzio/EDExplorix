<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EDExplorix.ViewModels"
        x:Class="EDExplorix.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="EDExplorix – Settings"
        Width="550" Height="220"
        CanResize="false">

    <Grid RowDefinitions="*,Auto" Margin="20">

        <StackPanel Grid.Row="0" Spacing="12">

            <TextBlock Text="Elite Dangerous journal folder"
                       Foreground="#888"
                       FontSize="12"/>

            <!-- Ścieżka + przycisk Browse -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding JournalPath}"
                         Watermark="Path to journal folder..."
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        Content="Browse..."
                        Command="{Binding BrowseCommand}"
                        Padding="12,6"/>
            </Grid>

            <!-- Status -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding StatusIcon}"
                           Foreground="{Binding StatusColor}"
                           FontSize="14"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#aaa"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>

        <!-- Przyciski -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBlock Grid.Column="0"
                       Text="Settings are saved to AppData/EDExplorix/config.json"
                       Foreground="#555"
                       FontSize="11"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Save"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsPathValid}"
                    Padding="20,6"
                    Background="#2a4a2a"
                    Foreground="#e0e0e0"/>
        </Grid>

    </Grid>
</Window>